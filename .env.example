# Argus Configuration Overrides
# Copy to .env and modify as needed

# Log level: DEBUG, INFO, WARNING, ERROR
ARGUS_LOG_LEVEL=INFO

# Authentication (required for production deployment)
ARGUS_AUTH_ENABLED=true
ARGUS_AUTH_TOKEN=change-me-to-a-secure-token

# Dashboard
ARGUS_DASHBOARD_HOST=0.0.0.0
ARGUS_DASHBOARD_PORT=8080

# Webhook for DCS integration
ARGUS_ALERTS_WEBHOOK_ENABLED=false
ARGUS_ALERTS_WEBHOOK_URL=http://plant-dcs:8080/foe-alerts

# Email alerts
ARGUS_ALERTS_EMAIL_ENABLED=false
ARGUS_ALERTS_EMAIL_SMTP_HOST=mail.plant.local
ARGUS_ALERTS_EMAIL_SMTP_PORT=587
ARGUS_ALERTS_EMAIL_FROM=argus@plant.local
ARGUS_ALERTS_EMAIL_RECIPIENTS=control-room@plant.local
ARGUS_ALERTS_EMAIL_MIN_SEVERITY=high
